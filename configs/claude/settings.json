{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash __HOME__/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true,
    "swift-lsp@claude-plugins-official": true,
    "ccusage-worv@worv": true
  },
  "extraKnownMarketplaces": {
    "worv": {
      "source": {
        "source": "github",
        "repo": "hletrd/ccusage-worv"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "ssh": {
      "command": "npx",
      "args": [
        "-y",
        "@aiondadotcom/mcp-ssh"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "context-mode": {
      "command": "npx",
      "args": [
        "-y",
        "context-mode"
      ]
    },
    "agent-browser": {
      "command": "npx",
      "args": [
        "-y",
        "agent-browser"
      ]
    }
  },
  "defaultMode": "bypassPermissions",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "autoMemoryEnabled": false
}
