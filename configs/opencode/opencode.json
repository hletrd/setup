{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "model": "openai/gpt-5.4",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "xhigh"
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "context-mode": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "context-mode"
      ],
      "enabled": true
    }
  }
}